{"accepted":[{"assertion":"Formal-Conjectures statement: FC 538 (PR #4079) [in-pr] https://github.com/google-deepmind/formal-conjectures/pull/4079.","id":"vf_a34f653b98d8c48d","trust":"signed","type":"theoretical"},{"assertion":"Erdős Problem #538: declared status 'open'. Formalized: no. Let $r\\geq 2$ and suppose that $A\\subseteq\\{1,\\ldots,N\\}$ is such that, for any $m$, there are at most $r$ solutions to $m=pa$ where $p$ is prime and $a\\in A$. Give the best possible upper bound for\\[\\sum_{n\\in A}\\frac{1}{n}.\\] Current best: Erd\\H{o}s observed that\\[\\sum_{n\\in A}\\frac{1}{n}\\sum_{p\\leq N}\\frac{1}{p}\\leq r\\sum_{m\\leq N^2}\\frac{1}{m}\\ll r\\log N,\\]and hence\\[\\sum_{n\\in A}\\frac{1}{n} \\ll r\\frac{\\log N}{\\log\\log N}.\\]See also [536] and [537]. Prize: no. Tags: number theory.","id":"vf_ee8d02940729d732","trust":"signed","type":"theoretical"}],"accepted_activity":false,"activity":[],"activity_types":[],"attempt_count":0,"banked_attempt_count":0,"commits":[],"dependency_impact":"none","detail_url":"problems/538.json","draft_proposals":[],"edges":[{"evidence":"Problem identity derived from the accepted finding's pinned source anchor.","inferred":true,"relation":"describes","source":"vf_a34f653b98d8c48d","source_root":"sha256:540d4967071425f77c693e61f62053208b07d67667490dcb9eeef62ec3f1d316","target":"erdos:538","trust":"signed"},{"evidence":"Materialized typed link between accepted findings.","inferred":true,"relation":"synthesized_from","source":"vf_a34f653b98d8c48d","source_root":"sha256:540d4967071425f77c693e61f62053208b07d67667490dcb9eeef62ec3f1d316","target":"vf_ee8d02940729d732","trust":"signed"},{"evidence":"Problem identity derived from the accepted finding's pinned source anchor.","inferred":true,"relation":"describes","source":"vf_ee8d02940729d732","source_root":"sha256:540d4967071425f77c693e61f62053208b07d67667490dcb9eeef62ec3f1d316","target":"erdos:538","trust":"signed"}],"external_references":[],"formal_conjectures_activity":null