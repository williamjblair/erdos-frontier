{"accepted":[{"assertion":"AI-contributions wiki claim — wiki: Partial result (Lean).","id":"vf_2669097e7896190a","trust":"signed","type":"theoretical"},{"assertion":"Erdős Problem #866: declared status 'open'. Formalized: no. Let $k\\geq 3$ and $g_k(N)$ be minimal such that if $A\\subseteq \\{1,\\ldots,2N\\}$ has $\\lvert A\\rvert \\geq N+g_k(N)$ then there exist integers $b_1,\\ldots,b_k$ such that all $\\binom{k}{2}$ pairwise sums are in $A$ (but the $b_i$ themselves need not be in $A$).\n\nEstimate $g_k(N)$. Prize: no. Tags: additive combinatorics, number theory.","id":"vf_27bffbf961eb7dc9","trust":"signed","type":"theoretical"},{"assertion":"Hosted Lean proof: plby proof of 866 (state partial) https://github.com/plby/lean-proofs/blob/main/src/v4.29.1/ErdosProblems/Erdos866.lean.","id":"vf_3ffee6bcccab3c08","trust":"signed","type":"theoretical"}],"accepted_activity":false,"activity":[],"activity_types":[],"attempt_count":0,"banked_attempt_count":0,"commits":[],"dependency_impact":"none","detail_url":"problems/866.json","draft_proposals":[],"edges":[{"evidence":"Problem identity derived from the accepted finding's pinned source anchor.","inferred":true,"relation":"describes","source":"vf_2669097e7896190a","source_root":"sha256:d3db36661e28b7570fc8704bf8455b80d8382beded47d069f2c386144d90a238","target":"erdos:866","trust":"signed"},{"evidence":"Problem identity derived from the accepted finding's pinned source anchor.","inferred":true,"relation":"describes","source":"vf_27bffbf961eb7dc9","source_root":"sha256:d3db36661e28b7570fc8704bf8455b80d8382beded47d069f2c386144d90a238","target":"erdos:866","trust":"signed"},{"evidence":"Problem identity derived from the accepted finding's pinned source anchor.","inferred":true,"relation":"describes","source":"vf_3ffee6bcccab3c08","source_root":"sha256:d3db36661e28b7570fc8704bf8455b80d8382beded47d069f2c386144d90a238","target":"erdos:866","trust":"signed"},{"evidence":"Materialized typed link between accepted findings.","inferre