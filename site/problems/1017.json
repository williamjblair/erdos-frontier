{"accepted":[{"assertion":"Formal-Conjectures statement: FC 1017 (PR #3422) [in-pr] https://github.com/google-deepmind/formal-conjectures/pull/3422.","id":"vf_13963a559dd68f7e","trust":"signed","type":"theoretical"},{"assertion":"Erdős Problem #1017: declared status 'open'. Formalized: no. Let $f(n,k)$ be such that every graph on $n$ vertices and $k$ edges can be partitioned into at most $f(n,k)$ edge-disjoint complete graphs. Estimate $f(n,k)$ for $k>n^2/4$. Current best: Lov\\'{a}sz \\cite{Lo68} proved that every graph on $n$ vertices and $k$ edges is the union of $\\binom{n}{2}-k+t$ complete graphs, where $t$ is maximal such that $t^2-t\\leq \\binom{n}{2}-k$, but without the assumption that the complete graphs are edge disjoint. Prize: no. Tags: graph theory.","id":"vf_d2b4a3c52d939967","trust":"signed","type":"theoretical"}],"accepted_activity":false,"activity":[],"activity_types":[],"attempt_count":0,"banked_attempt_count":0,"commits":[],"dependency_impact":"none","detail_url":"problems/1017.json","draft_proposals":[],"edges":[{"evidence":"Problem identity derived from the accepted finding's pinned source anchor.","inferred":true,"relation":"describes","source":"vf_13963a559dd68f7e","source_root":"sha256:d3db36661e28b7570fc8704bf8455b80d8382beded47d069f2c386144d90a238","target":"erdos:1017","trust":"signed"},{"evidence":"Materialized typed link between accepted findings.","inferred":true,"relation":"synthesized_from","source":"vf_13963a559dd68f7e","source_root":"sha256:d3db36661e28b7570fc8704bf8455b80d8382beded47d069f2c386144d90a238","target":"vf_d2b4a3c52d939967","trust":"signed"},{"evidence":"Problem identity derived from the accepted finding's pinned source anchor.","inferred":true,"relation":"describes","source":"vf_d2b4a3c52d939967","source_root":"sha256:d3db36661e28b7570fc8704bf8455b80d8382beded47d069f2c386144d90a238","target":"erdos:1017","trust":"signed"}],"external_references":[],"formal_conjectures_activity":null,"frontier_id":"vfr_0a25edabc16db143","