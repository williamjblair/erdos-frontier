{"accepted":[{"assertion":"Formal-Conjectures statement: FC 667 (PR #4370) [in-pr] https://github.com/google-deepmind/formal-conjectures/pull/4370.","id":"vf_3fdcaccc7862e054","trust":"signed","type":"theoretical"},{"assertion":"Erdős Problem #667: declared status 'open'. Formalized: no. Let $p,q\\geq 1$ be fixed integers. We define $H(n)=H(N;p,q)$ to be the largest $m$ such that any graph on $n$ vertices where every set of $p$ vertices spans at least $q$ edges must contain a complete graph on $m$ vertices.\nIs\\[c(p,q)=\\liminf \\frac{\\log H(n)}{\\log n}\\]a strictly increasing function of $q$ for $1\\leq q\\leq \\binom{p-1}{2}+1$? Prize: no. Tags: graph theory, ramsey theory.","id":"vf_48e9f3a6b85ab12c","trust":"signed","type":"theoretical"}],"accepted_activity":false,"activity":[],"activity_types":[],"attempt_count":0,"banked_attempt_count":0,"commits":[],"dependency_impact":"none","detail_url":"problems/667.json","draft_proposals":[],"edges":[{"evidence":"Problem identity derived from the accepted finding's pinned source anchor.","inferred":true,"relation":"describes","source":"vf_3fdcaccc7862e054","source_root":"sha256:d3db36661e28b7570fc8704bf8455b80d8382beded47d069f2c386144d90a238","target":"erdos:667","trust":"signed"},{"evidence":"Materialized typed link between accepted findings.","inferred":true,"relation":"synthesized_from","source":"vf_3fdcaccc7862e054","source_root":"sha256:d3db36661e28b7570fc8704bf8455b80d8382beded47d069f2c386144d90a238","target":"vf_48e9f3a6b85ab12c","trust":"signed"},{"evidence":"Problem identity derived from the accepted finding's pinned source anchor.","inferred":true,"relation":"describes","source":"vf_48e9f3a6b85ab12c","source_root":"sha256:d3db36661e28b7570fc8704bf8455b80d8382beded47d069f2c386144d90a238","target":"erdos:667","trust":"signed"}],"external_references":[],"formal_conjectures_activity":null,"frontier_id":"vfr_0a25edabc16db143","frontier_root":"sha256:d3db36661e28b7570fc8704bf8455b80d8382beded47d069f2c386144d90a238"