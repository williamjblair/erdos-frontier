{"accepted":[{"assertion":"Formal-Conjectures statement: Erdos325.erdos_325 https://google-deepmind.github.io/formal-conjectures/theorem/?name=Erdos325.erdos_325.","id":"vf_419156a8f13a0572","trust":"signed","type":"theoretical"},{"assertion":"Erdős Problem #325: declared status 'open'. Formalized: yes. Let $k\\geq 3$ and $f_{k,3}(x)$ denote the number of integers $\\leq x$ which are the sum of three nonnegative $k$th powers. Is it true that\\[f_{k,3}(x) \\gg x^{3/k}\\]or even $\\gg_\\epsilon x^{3/k-\\epsilon}$? Current best: For $k=3$ the best known is due to Wooley \\cite{Wo15},\\[f_{3,3}(x) \\gg x^{0.917\\cdots}.\\]This problem has been formalised in Lean as part of the Google DeepMind Formal Conjectures project. Prize: no. Tags: number theory, powers.","id":"vf_4b08b99a23120b16","trust":"signed","type":"theoretical"}],"accepted_activity":false,"activity":[],"activity_types":[],"attempt_count":0,"banked_attempt_count":0,"commits":[],"dependency_impact":"none","detail_url":"problems/325.json","draft_proposals":[],"edges":[{"evidence":"Problem identity derived from the accepted finding's pinned source anchor.","inferred":true,"relation":"describes","source":"vf_419156a8f13a0572","source_root":"sha256:d3db36661e28b7570fc8704bf8455b80d8382beded47d069f2c386144d90a238","target":"erdos:325","trust":"signed"},{"evidence":"Materialized typed link between accepted findings.","inferred":true,"relation":"synthesized_from","source":"vf_419156a8f13a0572","source_root":"sha256:d3db36661e28b7570fc8704bf8455b80d8382beded47d069f2c386144d90a238","target":"vf_4b08b99a23120b16","trust":"signed"},{"evidence":"Problem identity derived from the accepted finding's pinned source anchor.","inferred":true,"relation":"describes","source":"vf_4b08b99a23120b16","source_root":"sha256:d3db36661e28b7570fc8704bf8455b80d8382beded47d069f2c386144d90a238","target":"erdos:325","trust":"signed"}],"external_references":[],"formal_conjectures_activity":null,"frontier_id":"vfr_0a25edabc16db143","frontier_r