{"accepted":[{"assertion":"Formal-Conjectures statement: FC 478 (PR #4078) [in-pr] https://github.com/google-deepmind/formal-conjectures/pull/4078.","id":"vf_46104d8764ce0006","trust":"signed","type":"theoretical"},{"assertion":"Erdős Problem #478: declared status 'open'. Formalized: no. Let $p$ be a prime and\\[A_p = \\{ k! \\pmod{p} : 1\\leq k<p\\}.\\]Is it true that\\[\\lvert A_p\\rvert \\sim (1-\\tfrac{1}{e})p?\\] Current best: The best known lower bound is due to Grebennikov, Sagdeev, Semchankau, and Vasilevskii \\cite{GSSV24},\\[\\lvert A_p\\rvert \\geq (\\sqrt{2}-o(1))p^{1/2},\\]which follows from proving that $\\lvert A_pA_p\\rvert=(1+o(1))p$. Wilson's theorem implies $(p-2)!\\equiv 1\\pmod{p}$, and hence $\\lvert A_p\\rvert\\leq p-2$. Prize: no. OEIS: A210184. Tags: factorials, number theory.","id":"vf_4f70b474131c74ae","trust":"signed","type":"theoretical"}],"accepted_activity":false,"activity":[],"activity_types":[],"attempt_count":0,"banked_attempt_count":0,"commits":[],"dependency_impact":"none","detail_url":"problems/478.json","draft_proposals":[],"edges":[{"evidence":"Problem identity derived from the accepted finding's pinned source anchor.","inferred":true,"relation":"describes","source":"vf_46104d8764ce0006","source_root":"sha256:1faedc24f040a60a22177b456c74b969a61ce8836082297b1835797a57b4fa56","target":"erdos:478","trust":"signed"},{"evidence":"Materialized typed link between accepted findings.","inferred":true,"relation":"synthesized_from","source":"vf_46104d8764ce0006","source_root":"sha256:1faedc24f040a60a22177b456c74b969a61ce8836082297b1835797a57b4fa56","target":"vf_4f70b474131c74ae","trust":"signed"},{"evidence":"Problem identity derived from the accepted finding's pinned source anchor.","inferred":true,"relation":"describes","source":"vf_4f70b474131c74ae","source_root":"sha256:1faedc24f040a60a22177b456c74b969a61ce8836082297b1835797a57b4fa56","target":"erdos:478","trust":"signed"}],"external_references":[],"formal_conjectures_activity":null,"