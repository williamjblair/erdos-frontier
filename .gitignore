__pycache__/
*.pyc
.venv/
.pytest_cache/
# transient extractor scripts — regenerated each run from the template in
# extract_assumptions.py; the audit_feed*.json results are what we commit.
lean/extract_*.lean
# intermediate per-theorem records — folded into audit_feed*.json, read by nothing
lean/assumptions*.jsonl
# review packets — regenerated on demand by match_packet.py (a local worklist)
packets/
# transient search-witness scratch; accepted findings are committed, not the
# candidate stream
activity/
# vela.activity-record receipts — superseded by the signed events they mirror
records/
/.vela/agents/
/.vela/keys/
/.vela/operation-journals/
/.vela/tasks/
/.vela/work/
/.vela/workspaces/
/.vela/source-inbox/
/.vela/artifact-blobs/
